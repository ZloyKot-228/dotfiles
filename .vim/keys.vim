let mapleader = " "

" Basic
nnoremap ; :
nnoremap <Tab> :bnext<CR>
nnoremap <S-Tab> :bprevious<CR>

" Windows
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l
nnoremap <Leader>ss :vsplit<CR>
nnoremap <Leader>s- :split<CR>
nnoremap <Leader>q :bd<CR>

" Nerd tree
nnoremap <Leader>e :NERDTreeToggle<CR>
